<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/aliriocastro/index.json" />
  </packageSources>
  <!--
    Credentials are NOT stored here.

    Local dev (preferred): export env var via .env + direnv / dotenv-cli:
        NuGetPackageSourceCredentials_github="Username=<user>;Password=<PAT>"

    Local dev (alternative): write to the user-level NuGet config (outside the repo):
        dotnet nuget update source github -u USER -p PAT (with the store-password-in-clear-text flag)

    In CI, credentials are injected by the workflow.
  -->
</configuration>
