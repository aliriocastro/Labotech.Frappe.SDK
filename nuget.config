<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/aliriocastro/index.json" />
  </packageSources>
  <!--
    Credentials are NOT stored here.
    For local dev: dotnet nuget update source github -u aliriocastro -p YOUR_PAT
    In CI, credentials are injected by the workflow.
  -->
</configuration>
