# Copy to .env (which is gitignored) and fill in your GitHub PAT.
# Loaded with direnv, dotenv-cli, or `set -a && source .env && set +a`.
#
# NuGet reads this variable natively (v5.3+) for the source named "github"
# declared in nuget.config. No credentials live in the repo.

NuGetPackageSourceCredentials_github="Username=YOUR_GITHUB_USERNAME;Password=YOUR_GITHUB_PAT"
